{
  "scopeName": "source.xon",
  "name": "Xon",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#booleans"
    },
    {
      "include": "#null"
    },
    {
      "include": "#keys"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.xon",
          "begin": "//",
          "end": "$"
        },
        {
          "name": "comment.block.xon",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.xon",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.xon",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.xon",
          "match": "-?0[xX][0-9a-fA-F]+"
        },
        {
          "name": "constant.numeric.decimal.xon",
          "match": "-?(?:0|[1-9][0-9]*)(?:\\.[0-9]+)?(?:[eE][+-]?[0-9]+)?"
        }
      ]
    },
    "booleans": {
      "patterns": [
        {
          "name": "constant.language.boolean.xon",
          "match": "\\b(?:true|false)\\b"
        }
      ]
    },
    "null": {
      "patterns": [
        {
          "name": "constant.language.null.xon",
          "match": "\\bnull\\b"
        }
      ]
    },
    "keys": {
      "patterns": [
        {
          "name": "variable.other.key.xon",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b(?=\\s*:)"
        }
      ]
    }
  }
}
